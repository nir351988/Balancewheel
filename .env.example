# BalanceWheel Environment Configuration Template
# Copy this to .env and fill in your actual credentials
# NEVER commit .env to version control!

# Angel One Broker Credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP=000000

# Bot Configuration
DRY_RUN=true
LOG_LEVEL=INFO
CONFIG_FILE=config.json

# Database
DATABASE_FILE=data/balance_wheel.db

# Optional: Encryption Key (for securing credentials)
# ENCRYPTION_KEY=your_encryption_key_here
