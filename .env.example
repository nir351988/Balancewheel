# BalanceWheel Environment Configuration Template
# Copy this to .env and fill in your actual credentials
# NEVER commit .env to version control!

# Angel One Broker Credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
# Trading PIN / password (not the API key)
ANGEL_PASSWORD=your_password_here
# TOTP: 6-digit code OR secret key from https://smartapi.angelbroking.com/enable-totp
ANGEL_TOTP=your_totp_secret_or_code
# Alternative name for TOTP secret (pyotp generates the 6-digit code automatically)
# ANGEL_TOTP_SECRET=your_totp_secret_key

# Bot runs LIVE by default (config.json dry_run: false).
# Uncomment only for manual/agent testing — no real orders when enabled:
# DRY_RUN=true
# PAPER_TRADING=true
LOG_LEVEL=INFO
CONFIG_FILE=config.json

# Database
DATABASE_FILE=data/balance_wheel.db

# Optional: GitHub log push (see LOGGING.md)
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_REPO=https://github.com/youruser/yourrepo.git

# Optional: Encryption Key (for securing credentials)
# ENCRYPTION_KEY=your_encryption_key_here
